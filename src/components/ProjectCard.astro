---
import type { CollectionEntry } from 'astro:content';

type Project = CollectionEntry<'projects'>;

interface Props {
  project: Project;
  headingLevel?: 'h2' | 'h3';
}

const { project, headingLevel = 'h3' } = Astro.props;
const Heading = headingLevel;
const { title, description, tech, repoUrl, liveUrl, featured, impact } = project.data;
const slug = project.id.replace(/\.(md|mdx)$/, '');
const projectUrl = `/projects/${slug}/`;
---

<article class="project-card card">
  <div class="stack">
    <div class="card-topline">
      {featured && <span class="featured">Featured</span>}
      <span class="subtle">Project</span>
    </div>
    <div class="stack">
      <Heading><a href={projectUrl}>{title}</a></Heading>
      <p class="muted">{description}</p>
    </div>
    {impact && <p class="impact"><strong>Impact:</strong> {impact}</p>}
    <ul class="pill-list" aria-label={`${title} technologies`}>
      {tech.map((item) => <li class="pill">{item}</li>)}
    </ul>
  </div>
  <div class="card-links" aria-label={`${title} links`}>
    <a href={projectUrl}>Case study</a>
    {repoUrl && <a href={repoUrl}>Repo</a>}
    {liveUrl && <a href={liveUrl}>Live</a>}
  </div>
</article>

<style>
  .project-card {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: var(--space-6);
    min-height: 100%;
  }

  .project-card h2,
  .project-card h3 {
    font-size: var(--text-2xl);
  }

  .project-card h2 a,
  .project-card h3 a {
    color: var(--color-text);
    text-decoration: none;
  }

  .project-card h2 a:hover,
  .project-card h3 a:hover {
    color: var(--color-accent-hover);
  }

  .card-topline,
  .card-links {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-3);
  }

  .card-topline {
    justify-content: space-between;
    font-size: var(--text-xs);
    font-weight: var(--weight-bold);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .featured {
    border-radius: var(--radius-full);
    background: var(--color-accent-soft);
    color: var(--color-accent-hover);
    padding: var(--space-1) var(--space-3);
  }

  .impact {
    color: var(--color-text-muted);
    font-size: var(--text-sm);
  }

  .card-links a {
    font-size: var(--text-sm);
    font-weight: var(--weight-bold);
  }
</style>

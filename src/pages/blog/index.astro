---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="Blog | Himanshu Singh" description="Technical writing and project notes by Himanshu Singh on platform engineering, Kafka, Kubernetes, cloud infrastructure, automation, and reliability.">
  <section class="page-header">
    <div class="container reading">
      <p class="eyebrow">Blog</p>
      <h1>Technical writing and notes.</h1>
      <p class="lead">Practical notes from building platform infrastructure — Kafka and streaming systems, secured Kubernetes, migration automation, observability, and reliability lessons learned along the way.</p>
    </div>
  </section>

  <section class="section">
    <div class="container card-grid">
      {posts.map((post) => <PostCard post={post} headingLevel="h2" />)}
    </div>
  </section>
</BaseLayout>
